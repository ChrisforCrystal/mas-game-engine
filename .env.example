# docker compose 环境变量

# ── arena-ui ──────────────────────────────────────────────────────────────────
# arena-ui 构建时会把这个地址打包进前端 JS，同事访问时浏览器会请求这个地址
NEXT_PUBLIC_ARENA_API=http://your-host-ip-or-domain:9090

# ── arena-api ─────────────────────────────────────────────────────────────────
# 数据目录：arena.db、logs/、artifacts/replays/ 都写到这个目录下
# 容器部署时设为 NAS 挂载路径，例如 /app/nas
# 本地开发不设则默认为当前目录
ARENA_DATA_DIR=/app/nas

# 日志目录（可选，默认为 ARENA_DATA_DIR/logs）
# ARENA_LOG_DIR=/app/nas/logs
